# ============================================================
# Payslip Tool Configuration for Phuc Long
# ============================================================
# Copy this file to .env and update values before running.

# ── Excel File Path ──────────────────────────────────────────
# Path to the source Excel file (absolute or relative to tool dir)
PAYSLIP_EXCEL_PATH=./excel-files/TBKQ-phuclong.xls

# ── Sheet Names ──────────────────────────────────────────────
DATA_SHEET=Data
TEMPLATE_SHEET=TBKQ
EMAIL_BODY_SHEET=bodymail

# ── Data Sheet Structure ────────────────────────────────────
# Row numbers (1-based)
DATA_HEADER_ROW=2
DATA_START_ROW=4

# ── Data Sheet Column Mappings ───────────────────────────────
DATA_COLUMN_MNV=A
DATA_COLUMN_NAME=B
DATA_COLUMN_EMAIL=C
DATA_COLUMN_PASSWORD=AZ

# ── Payroll Date (MM/YYYY) ──────────────────────────────────
DATE=01/2026

# ── Outlook Configuration ───────────────────────────────────
OUTLOOK_ACCOUNT=your.email@company.com

# ── Email Configuration ─────────────────────────────────────
# Leave EMAIL_SUBJECT empty to read from TBKQ sheet
EMAIL_SUBJECT=
EMAIL_SUBJECT_CELL=G1
EMAIL_BODY_CELLS=A1,A3,A5,A7,A9,A11,A12
EMAIL_DATE_CELL=A3

# ── Processing Options ──────────────────────────────────────
DRY_RUN=true
BATCH_SIZE=50

# ── PDF Options ──────────────────────────────────────────────
PDF_PASSWORD_ENABLED=true
PDF_PASSWORD_STRIP_LEADING_ZEROS=true
PDF_FILENAME_PATTERN=TBKQ_{name}_{mmyyyy}.pdf

# ── Output Paths ─────────────────────────────────────────────
OUTPUT_DIR=./output
LOG_DIR=./logs
STATE_DIR=./state
LOG_LEVEL=INFO

# ── TBKQ Title/Info Cells ───────────────────────────────────
TBKQ_TITLE_CELL=G1
TBKQ_INFO_CELL=A2
TBKQ_PERIOD_CELL=A10

# ============================================================
# TBKQ Cell-to-Data Column Mapping
# ============================================================
# Format: TBKQ_MAP_<CELL>=<DATA_COLUMN>
# These define which Data sheet column provides the value
# for each TBKQ template cell.

# Employee info
TBKQ_MAP_B3=A
TBKQ_MAP_B4=B
TBKQ_MAP_D3=F

# Work info (row 10)
TBKQ_MAP_B10=J
TBKQ_MAP_C10=K
TBKQ_MAP_D10=N

# Income details
TBKQ_MAP_D18=O
TBKQ_MAP_D24=P
TBKQ_MAP_D28=T
TBKQ_MAP_D31=Q
TBKQ_MAP_D32=R
TBKQ_MAP_D33=S
TBKQ_MAP_D37=V

# Deductions
TBKQ_MAP_D44=Z
TBKQ_MAP_D48=AA
TBKQ_MAP_D50=AB
TBKQ_MAP_D51=AC
TBKQ_MAP_D52=AD

# Net payment
TBKQ_MAP_D53=AH

# ============================================================
# Calculated Cells
# ============================================================
# Format: TBKQ_CALC_<CELL>=<formula>
#   - "COL1+COL2": Sum of Data columns
#   - "=CELL1+CELL2": Sum of other TBKQ cells
#   - "0": Direct value

TBKQ_CALC_D38=U+W+X+Y
TBKQ_CALC_D17==D18
TBKQ_CALC_D22==D24+D28
TBKQ_CALC_D30==D31+D32+D33+D37+D38
TBKQ_CALC_D21==D22+D30
TBKQ_CALC_D16==D17+D21
TBKQ_CALC_D45=0
TBKQ_CALC_D40==D44+D45+D48
TBKQ_CALC_D49==D50+D51
TBKQ_CALC_D39==D40+D49+D52
