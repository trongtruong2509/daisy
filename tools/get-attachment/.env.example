# ============================================================
# Get Attachment Tool Configuration
# ============================================================
# Copy this file to .env and update values before running.
# All values are optional — the tool will prompt for anything
# that is not set here.

# ── Outlook Account ──────────────────────────────────────────────
# SMTP address of the Outlook account to search.
# If omitted, the tool will list available accounts and prompt you to choose.
# OUTLOOK_ACCOUNT=your.email@company.com

# ── Search Criteria ──────────────────────────────────────────────
# Start date for the email search range (DD/MM/YYYY).
# If omitted, the tool will prompt you each run.
# START_DATE=01/03/2026

# End date for the email search range (DD/MM/YYYY).
# If omitted, the tool will prompt you — leave the prompt blank to use today's date.
# END_DATE=02/03/2026

# Subject keywords to filter emails (comma-separated, case-insensitive OR logic).
# Leave empty (or omit) to download attachments from ALL emails in the date range.
# SUBJECT_KEYWORDS=invoice,report,payslip

# ── Output ───────────────────────────────────────────────────────
# Directory where attachments will be saved (absolute or relative to this file).
# If omitted, the tool will prompt you.
# ATTACHMENT_SAVE_PATH=D:\Downloads\attachments

# ── Logging ──────────────────────────────────────────────────────
LOG_DIR=./logs
LOG_LEVEL=INFO
