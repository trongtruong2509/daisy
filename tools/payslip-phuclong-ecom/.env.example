# ============================================================
# Payslip Tool Configuration for Phuc Long (Excel COM variant)
# ============================================================
# Copy this file to .env and update values before running.

#  Excel File Path 
# Path to the source Excel file (absolute or relative to tool dir)
PAYSLIP_EXCEL_PATH=D:\repos\trongtruong2509\daisy\excel-files\TBKQ-phuclong.xls

# Payroll Date (MM/YYYY) 
# This date will be asked while using the tool. But you can set here.
# DATE=01/2026

# Outlook Configuration
# This must match one of the accounts configured in your Outlook profile
# OUTLOOK_ACCOUNT=your.email@company.com

# Processing Options 
DRY_RUN=true
BATCH_SIZE=50
ALLOW_DUPLICATE_EMAILS=false

# PDF Options 
PDF_PASSWORD_ENABLED=true
PDF_PASSWORD_STRIP_LEADING_ZEROS=true
PDF_FILENAME_PATTERN=TBKQ_{name}_{mmyyyy}

# Output Paths
OUTPUT_DIR=./output
LOG_DIR=./logs
STATE_DIR=./state
LOG_LEVEL=INFO

#  Sheet Names 
DATA_SHEET=Data
TEMPLATE_SHEET=TBKQ
EMAIL_BODY_SHEET=bodymail

#  Data Sheet Structure 
# Row numbers (1-based)
DATA_HEADER_ROW=2
DATA_START_ROW=4

#  Data Sheet Column Mappings ─
DATA_COLUMN_MNV=A
DATA_COLUMN_NAME=B
DATA_COLUMN_EMAIL=C
DATA_COLUMN_PASSWORD=AZ

#  Email Configuration
# Leave EMAIL_SUBJECT empty to read from TBKQ sheet
EMAIL_SUBJECT=
EMAIL_SUBJECT_CELL=G1
EMAIL_BODY_CELLS=A1,A3,A5,A7,A9,A11,A12
EMAIL_DATE_CELL=A3


